<table>
    <tr>
        <th> Id </th>
        <th> Name </th>
        <th> Journal Entry </th>
        <th> Image </th>
    </tr>
    
    @foreach (var pin in @Model)
    {
        <tr>
            <td><a href="/Pin/ViewPin/@pin.PinId">@pin.PinId</a></td>
            <td><a href="/Pin/ViewPin/@pin.PinId">@pin.PinName</a></td>
            <td>@pin.PinJournal</td>
            <td>@pin.PinImage</td>
        </tr>
    }
    
</table>

    